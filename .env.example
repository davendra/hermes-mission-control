# Copy this file to .env and fill in your values.

# Database (Vercel Postgres / Neon / Supabase / local Postgres all work)
DATABASE_URL="postgresql://user:password@host:5432/hermes?sslmode=require"

# Shared secret agents use to authenticate when POSTing state updates.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=""

# Dashboard login (HTTP Basic Auth via src/middleware.ts). Gates the UI pages
# so agent state/costs aren't world-readable. If both are blank the gate is a
# no-op (fine for local dev). API routes are NOT gated by this — they use
# INTERNAL_API_SECRET (Bearer). Generate a pass with: openssl rand -base64 18
DASHBOARD_USER="admin"
DASHBOARD_PASS=""

# Optional: AI provider. Only needed if your agents call LLMs from inside
# this codebase. Most setups keep LLM calls inside the agent process itself
# and just report results here, in which case you can leave this blank.
OPENROUTER_API_KEY=""
